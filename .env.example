# -------------------------------------------------
# Imotara Web — Environment Variables (Example)
# Copy to .env.local for local dev.
# For production (Vercel), set these in Project Settings → Environment Variables.
# -------------------------------------------------

# -------------------------------------------------
# 🔐 Supabase
# -------------------------------------------------
# Public (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------
# 🔐 NextAuth (Web only)
# -------------------------------------------------
# Local dev:
# NEXTAUTH_URL=http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# Browser-visible base URL (local dev: http://localhost:3000)
NEXT_PUBLIC_IMOTARA_API_BASE_URL=

# -------------------------------------------------
# 🧠 Analysis Mode
# -------------------------------------------------
# local | api
NEXT_PUBLIC_IMOTARA_ANALYSIS=api

# -------------------------------------------------
# ✨ AI ENGINE INTEGRATION (Server-only)
# -------------------------------------------------
OPENAI_API_KEY=
IMOTARA_AI_MODEL=gpt-4.1
# IMOTARA_OPENAI_BASE_URL=https://api.openai.com

# -------------------------------------------------
# 🌟 App Version
# -------------------------------------------------
NEXT_PUBLIC_IMOTARA_VERSION=0.0.2
NEXT_PUBLIC_APP_VERSION=0.0.2

# -------------------------------------------------
# 🔐 Licensing mode
# -------------------------------------------------
# off | log | enforce
NEXT_PUBLIC_IMOTARA_LICENSE_MODE=off

# -------------------------------------------------
# 🎁 Launch offer — free "pro" trial for all users
# -------------------------------------------------
# Set to the ISO date of your public launch (e.g. 2026-03-14).
# All users get a "pro" trial for FREE_DAYS days from that date.
# Leave blank to disable the offer.
NEXT_PUBLIC_IMOTARA_LAUNCH_DATE=2026-03-14
NEXT_PUBLIC_IMOTARA_FREE_DAYS=120

# -------------------------------------------------
# 💝 Donations (Razorpay — server only)
# -------------------------------------------------
IMOTARA_DONATION_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
