# -------------------------------------------------
# Imotara Web — Environment Variables (Example)
# Copy to .env.local for local dev.
# For production (Vercel), set these in Project Settings → Environment Variables.
# -------------------------------------------------

# -------------------------------------------------
# 🔐 Supabase
# -------------------------------------------------
# Public (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------
# 🔐 NextAuth (Web only)
# -------------------------------------------------
# Local dev:
# NEXTAUTH_URL=http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# Browser-visible base URL (local dev: http://localhost:3000)
NEXT_PUBLIC_IMOTARA_API_BASE_URL=

# -------------------------------------------------
# 🧠 Analysis Mode
# -------------------------------------------------
# local | api
NEXT_PUBLIC_IMOTARA_ANALYSIS=api

# -------------------------------------------------
# ✨ AI ENGINE INTEGRATION (Server-only)
# -------------------------------------------------
OPENAI_API_KEY=
IMOTARA_AI_MODEL=gpt-4.1-mini
# IMOTARA_OPENAI_BASE_URL=https://api.openai.com

# -------------------------------------------------
# 🌟 App Version
# -------------------------------------------------
NEXT_PUBLIC_IMOTARA_VERSION=1.2.3
NEXT_PUBLIC_APP_VERSION=1.2.3

# -------------------------------------------------
# 🔐 Licensing mode
# -------------------------------------------------
# off | log | enforce
NEXT_PUBLIC_IMOTARA_LICENSE_MODE=off

# -------------------------------------------------
# 🎁 Launch offer — free "pro" trial for all users
# -------------------------------------------------
# Set to the ISO date of your public launch (e.g. 2026-03-14).
# All users get a "pro" trial for FREE_DAYS days from that date.
# Leave blank to disable the offer.
NEXT_PUBLIC_IMOTARA_LAUNCH_DATE=2026-03-14
NEXT_PUBLIC_IMOTARA_FREE_DAYS=120

# -------------------------------------------------
# 💝 Donations (Razorpay — server only)
# -------------------------------------------------
IMOTARA_DONATION_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# -------------------------------------------------
# 🔔 Web Push Notifications (VAPID)
# -------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -------------------------------------------------
# 🤝 Imotara Connect (server only unless noted)
# -------------------------------------------------
# Cron job secret — Vercel sends this as "Authorization: Bearer <value>"
# for all scheduled routes. Required for connect-orphans, connect-scheduled,
# wallet crons, and exchange-rates.
CRON_SECRET=

# Imotara Connect wallet top-up (Razorpay)
# NEXT_PUBLIC_ variant is used by the browser to load the checkout script.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Server-only — never expose to the browser.
RAZORPAY_CONNECT_KEY_SECRET=

# Transactional email (Connect session notifications, approval/rejection)
# Uses nodemailer over Hostinger or Gmail SMTP (port 465, secure: true).
# SMTP_HOST defaults to smtp.hostinger.com if not set.
SMTP_HOST=
ALERT_GMAIL_USER=
ALERT_GMAIL_APP_PASSWORD=

# Internal email that receives platform revenue notifications after every session.
# Defaults to info@imotara.com if not set.
CONNECT_PLATFORM_EMAIL=

# Admin security — set to "true" in production to disable the legacy
# ADMIN_SECRET Bearer-token fallback on all /api/admin/* routes.
# Without this flag, anyone holding ADMIN_SECRET can authenticate as admin.
ADMIN_SECRET_DISABLED=true

# Legacy admin secret (used only when ADMIN_SECRET_DISABLED is not "true")
ADMIN_SECRET=

# ── Azure Neural TTS (used by /api/tts; regional routing per user country) ──
# At minimum set the IN pair; EU/US/AP pairs are optional regional fallbacks.
AZURE_SPEECH_KEY_IN=
AZURE_SPEECH_REGION_IN=centralindia
AZURE_SPEECH_KEY_EU=
AZURE_SPEECH_REGION_EU=
AZURE_SPEECH_KEY_US=
AZURE_SPEECH_REGION_US=
AZURE_SPEECH_KEY_AP=
AZURE_SPEECH_REGION_AP=

# ── Stripe (international payments; optional if Razorpay-only) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs per product, convention STRIPE_PRICE_{PRODUCT_ID_UPPER}:
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# ── Apple In-App Purchase server verification (/api/license/verify-apple-purchase) ──
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY=

# ── Google Play purchase verification (/api/payments/google-play/verify) ──
# Full service-account JSON as a single-line string.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ── Donations ──
# Must be "true" for /api/payments/donation-intent to accept donations.
IMOTARA_DONATION_ENABLED=true
